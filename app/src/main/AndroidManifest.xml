        <activity
            android:name=".AuthorityProfileActivity"
            android:exported="false" />
        <activity
            android:name=".AuthorityMainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        <activity
            android:name=".NotificationsActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        <activity
            android:name=".AuthorityComplaintsActivity"
            android:exported="false" />
        <activity
            android:name=".DepartmentInfoActivity"
            android:exported="false" />
        <activity
            android:name=".AuthorityEditProfileActivity"
            android:exported="false" />
        <activity
            android:name=".AuthoritySettingsActivity"
            android:exported="false" />
        <activity
            android:name=".AuthorityPasswordSuccessActivity"
            android:exported="false" />
        <activity
            android:name=".AuthorityHelpActivity"

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:paddingBottom="42dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/sheetLayout"
        app:layout_constraintVertical_chainStyle="packed">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="24dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/app_logo"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_account_title"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_account_desc"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- White Bottom Sheet -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/sheetLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_sheet_rounded_top"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="12dp"
                android:drawableTint="@color/text_secondary"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:hint="@string/hint_full_name"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <!-- Mobile Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mobile_number"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etMobile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@android:drawable/sym_action_call"
                android:drawablePadding="12dp"
                android:drawableTint="@color/text_secondary"
                android:inputType="phone"
                android:paddingHorizontal="12dp"
                android:hint="@string/hint_mobile_code"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <!-- Email Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_address"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@android:drawable/sym_action_email"
                android:drawablePadding="12dp"
                android:drawableTint="@color/text_secondary"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:hint="@string/hint_email"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <!-- Aadhaar Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/aadhaar_label"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etAadhaar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@android:drawable/ic_menu_compass"
                android:drawablePadding="12dp"
                android:drawableTint="@color/text_secondary"
                android:inputType="number"
                android:maxLength="14"
                android:paddingHorizontal="12dp"
                android:hint="@string/hint_aadhaar"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/password"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@android:drawable/ic_lock_idle_lock"
                android:drawablePadding="12dp"
                android:drawableTint="@color/text_secondary"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:hint="@string/hint_password_dots"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <!-- Confirm Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confirm_password_label"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@android:drawable/ic_lock_idle_lock"
                android:drawablePadding="12dp"
                android:drawableTint="@color/text_secondary"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:hint="@string/hint_password_dots"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <!-- Terms and Conditions -->
            <CheckBox
                android:id="@+id/cbTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/terms_conditions"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="16dp" 
                android:buttonTint="@color/login_button"/>

            <!-- Register Button -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/login_button"
                android:text="@string/register_btn"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp" />

            <!-- Login Link -->
            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/already_have_account"
                android:textColor="@color/login_button"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:padding="8dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
